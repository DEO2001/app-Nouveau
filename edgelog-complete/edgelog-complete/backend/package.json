{
  "name": "edgelog-backend",
  "version": "1.0.0",
  "description": "EDGELOG — API REST Node.js/Express + Prisma + Stripe",
  "main": "src/index.js",
  "scripts": {
    "dev":            "nodemon src/index.js",
    "start":          "node src/index.js",
    "db:push":        "prisma db push",
    "db:migrate":     "prisma migrate dev",
    "db:studio":      "prisma studio",
    "db:seed":        "node prisma/seed.js",
    "db:reset":       "prisma migrate reset --force && npm run db:seed",
    "test":           "NODE_ENV=test jest --forceExit",
    "test:watch":     "NODE_ENV=test jest --watch",
    "test:coverage":  "NODE_ENV=test jest --coverage --forceExit",
    "test:ci":        "NODE_ENV=test jest --coverage --forceExit --ci --runInBand",
    "test:unit":      "NODE_ENV=test jest --forceExit --testPathPattern='(auth|plans|trades|analytics|stripe)\\.test\\.js'",
    "test:verbose":   "NODE_ENV=test jest --forceExit --verbose"
  },
  "dependencies": {
    "@prisma/client":           "^5.10.0",
    "bcryptjs":                 "^2.4.3",
    "cors":                     "^2.8.5",
    "dotenv":                   "^16.4.1",
    "express":                  "^4.18.3",
    "express-rate-limit":       "^7.2.0",
    "express-validator":         "^7.0.1",
    "helmet":                   "^7.1.0",
    "jsonwebtoken":             "^9.0.2",
    "morgan":                   "^1.10.0",
    "multer":                   "^1.4.5-lts.1",
    "node-cron":                "^3.0.3",
    "papaparse":                "^5.4.1",
    "passport":                 "^0.7.0",
    "passport-google-oauth20":  "^2.0.0",
    "resend":                   "^3.2.0",
    "stripe":                   "^14.18.0",
    "uuid":                     "^9.0.0"
  },
  "devDependencies": {
    "jest":              "^29.7.0",
    "nodemon":           "^3.1.0",
    "prisma":            "^5.10.0",
    "supertest":         "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
